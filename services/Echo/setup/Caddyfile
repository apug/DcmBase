echo1.{$CADDY_MAIN_DOMAIN} {
	reverse_proxy echo1:8080 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Port {server_port}
		header_up X-Real-IP {remote_host}
		header_up Host {host}
	}
	tls internal
}

echo2.{$CADDY_MAIN_DOMAIN} {
	reverse_proxy echo2:8080 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Port {server_port}
		header_up X-Real-IP {remote_host}
		header_up Host {host}
	}
	tls internal
}
